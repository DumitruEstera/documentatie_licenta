% Header and footer styles and their appliances on different generated components
% Regula de tehnoredactare: caracterul lucrarii (NECLASIFICAT) centrat, majuscule,
% size 10, Times New Roman, in Header si Footer; sub Footer "<pagina> din <total>".
\renewcommand{\headrulewidth}{1pt}
\renewcommand{\footrulewidth}{1pt}
\newcommand{\neclasif}{{\fontsize{10}{12}\selectfont NECLASIFICAT}}
\fancypagestyle{front}{
  \fancyhf{}
  \fancyhead[C]{\neclasif}
  \fancyfoot[C]{\neclasif\\{\fontsize{10}{12}\selectfont\thepage\ din \pageref*{LastPage}}}
}
\pagestyle{front}
\fancypagestyle{plain}{
  \fancyhf{}
  \fancyhead[C]{\neclasif}
  \fancyfoot[C]{\neclasif\\{\fontsize{10}{12}\selectfont\thepage\ din \pageref*{LastPage}}}
}
% Numerotare araba continua pentru intreaga lucrare (foaia de titlu nu se numeroteaza)
\newenvironment{frontmatter}{\pagenumbering{arabic}}{\newpage}
\AtBeginDocument{\addtocontents{toc}{\protect\thispagestyle{front}}}
\addtocontents{lof}{\protect\thispagestyle{front}}

% Custom command for bold and italic text
\newcommand{\textbfit}[1]{\textbf{\textit{#1}}}

% Custom command for inline code
\newenvironment{codeenv}{\fontfamily{cmtt}\selectfont}{\par}
\DeclareTextFontCommand{\inlinecodenonboxed}{\codeenv}
\newcommand{\inlinecode}[1]{\mbox{\inlinecodenonboxed{#1}}}

% Python code listings (minted + Pygments)
% ATENTIE: necesita compilare cu pdflatex -shell-escape (seteaza flag-ul in TeXstudio).
\usepackage[chapter]{minted}   % numeroteaza listing-urile per capitol -> "Listing 5.1"
\usemintedstyle{vs}      % stil de colorare (se schimba dintr-o singura linie)
\setminted{
  fontsize=\footnotesize,
  linenos,                                   % numere de linie in stanga
  numbersep=8pt,
  breaklines,                                % rupe liniile prea lungi
  breakanywhere=false,                       % rupe doar la spatii, nu in mijlocul unui token
  breakindent=0pt,
  breaksymbolleft=\textcolor{gray}{\footnotesize$\hookrightarrow$},  % marcaj de continuare
  frame=lines,                               % linii sus si jos (ca vechiul frame=tb)
  framesep=2mm,
  rulecolor=\color{gray!50},
  xleftmargin=1.5em,
  tabsize=4,
  autogobble,                                % elimina indentarea comuna din fata
}
\renewcommand{\listingscaption}{Listing}
\renewcommand{\listoflistingscaption}{Listă de Listinguri}

% Spatiere verticala naturala: nu intinde paragrafele ca sa umple pagina cand un
% listing/tabel este impins pe pagina urmatoare. Golul ramane la finalul paginii.
\raggedbottom

% Custom abbreviation item
\newenvironment{abbreviations}{\begin{list}{}{\renewcommand{\makelabel}{\abbrlabel}}}{\end{list}}
\newcommand{\abbrlabel}[1]{\makebox[3cm][l]{\textbf{#1}\ \dotfill}}

